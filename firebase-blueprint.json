{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile picture URL"
        },
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of package names the user has favorited"
        },
        "selectedRepos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of repository URLs the user has selected"
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles and preferences"
    }
  }
}
